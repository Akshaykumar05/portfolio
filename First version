  <style>
    :root {
      --bg: #070710;
      --surface: #0f0f1c;
      --surface2: #171728;
      --border: #252538;
      --accent: #6ee7b7;
      --accent2: #38bdf8;
      --accent3: #f472b6;
      --text: #ddddf0;
      --muted: #6868a0;
      --heading: #ffffff;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      overflow-x: hidden;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 9999; opacity: .6;
    }

    /* CURSOR */
    .cursor { width: 9px; height: 9px; background: var(--accent); border-radius: 50%; position: fixed; pointer-events: none; z-index: 10000; transform: translate(-50%,-50%); transition: transform .15s ease; }
    .cursor-ring { width: 34px; height: 34px; border: 1.5px solid var(--accent); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); opacity: .4; transition: transform .35s cubic-bezier(.23,1,.32,1), opacity .3s; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.2rem 3rem;
      background: rgba(7,7,16,.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.1rem; color: var(--heading); text-decoration: none; letter-spacing: -.02em; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: .73rem; letter-spacing: .14em; text-transform: uppercase; transition: color .2s; }
    .nav-links a:hover { color: var(--accent); }
    .nav-badge { background: var(--accent); color: #070710; font-size: .65rem; padding: .3rem .75rem; border-radius: 100px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; }

    /* HERO */
    #hero {
      min-height: 100vh;
      display: flex; flex-direction: column; justify-content: center;
      padding: 8rem 3rem 5rem;
      position: relative; overflow: hidden;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image: linear-gradient(rgba(110,231,183,.035) 1px,transparent 1px), linear-gradient(90deg,rgba(110,231,183,.035) 1px,transparent 1px);
      background-size: 52px 52px;
      mask-image: radial-gradient(ellipse 85% 65% at 55% 40%, black 25%, transparent 75%);
    }
    .orb { position: absolute; border-radius: 50%; filter: blur(90px); pointer-events: none; }
    .orb1 { width: 550px; height: 550px; background: rgba(110,231,183,.1); top: -150px; right: -50px; }
    .orb2 { width: 320px; height: 320px; background: rgba(56,189,248,.08); bottom: 0; left: 80px; }
    .orb3 { width: 220px; height: 220px; background: rgba(244,114,182,.06); top: 220px; left: 250px; }

    .hero-chip {
      display: inline-flex; align-items: center; gap: .5rem;
      background: rgba(110,231,183,.08);
      border: 1px solid rgba(110,231,183,.2);
      border-radius: 100px; padding: .4rem 1rem;
      font-size: .72rem; letter-spacing: .12em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 2rem;
      width: fit-content;
    }
    .hero-chip::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{ opacity:1; } 50%{ opacity:.3; } }

    h1 {
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(3.2rem, 8.5vw, 7.5rem);
      line-height: .93; letter-spacing: -.04em;
      color: var(--heading); margin-bottom: 1.75rem;
    }
    h1 .line2 {
      background: linear-gradient(130deg, var(--accent) 0%, var(--accent2) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    .hero-sub {
      font-family: 'Instrument Serif', serif;
      font-size: 1.15rem; color: var(--muted);
      margin-bottom: .6rem; font-style: italic;
    }
    .hero-desc { font-size: .88rem; color: var(--muted); max-width: 500px; line-height: 1.85; margin-bottom: 2.5rem; }

    .hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 3.5rem; }
    .btn {
      display: inline-flex; align-items: center; gap: .6rem;
      padding: .8rem 1.7rem; border-radius: 5px;
      font-family: 'DM Mono', monospace; font-size: .78rem;
      letter-spacing: .07em; text-transform: uppercase;
      text-decoration: none; cursor: pointer; border: none;
      transition: all .25s ease;
    }
    .btn-primary { background: var(--accent); color: #070710; font-weight: 500; }
    .btn-primary:hover { background: #a7f3d0; transform: translateY(-2px); box-shadow: 0 10px 35px rgba(110,231,183,.22); }
    .btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    .hero-numbers {
      display: flex; flex-wrap: wrap; gap: 2.5rem;
    }
    .hero-num { }
    .hero-num .n {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2.2rem;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-num .l { font-size: .72rem; color: var(--muted); letter-spacing: .1em; display: block; margin-top: .15rem; }

    /* SECTION SHARED */
    section { padding: 6rem 3rem; }
    .section-tag {
      font-size: .7rem; letter-spacing: .22em; text-transform: uppercase;
      color: var(--accent); margin-bottom: .85rem;
      display: flex; align-items: center; gap: .7rem;
    }
    .section-tag::before { content: '//'; opacity: .5; }
    h2 {
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: clamp(1.9rem, 4.5vw, 3.2rem);
      letter-spacing: -.03em; color: var(--heading); margin-bottom: 1rem;
    }
    .divider { border: none; border-top: 1px solid var(--border); }

    /* ABOUT */
    #about { display: grid; grid-template-columns: 1.1fr 1fr; gap: 5rem; align-items: center; }
    .about-text p { color: var(--muted); line-height: 1.95; margin-bottom: 1.1rem; font-size: .87rem; }
    .about-text p strong { color: var(--text); font-weight: 500; }
    .about-tags { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: 1.5rem; }
    .tag {
      background: var(--surface2); border: 1px solid var(--border);
      border-radius: 4px; padding: .3rem .75rem;
      font-size: .73rem; color: var(--muted); letter-spacing: .05em;
    }

    .about-right { display: flex; flex-direction: column; gap: 1.25rem; }
    .info-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.5rem 1.75rem;
      display: flex; align-items: center; gap: 1.25rem;
      transition: border-color .3s, transform .3s;
      text-decoration: none;
    }
    .info-card:hover { border-color: var(--accent); transform: translateX(5px); }
    .info-icon {
      width: 46px; height: 46px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; flex-shrink: 0;
    }
    .info-icon.green { background: rgba(110,231,183,.12); }
    .info-icon.blue { background: rgba(56,189,248,.12); }
    .info-icon.purple { background: rgba(167,139,250,.12); }
    .info-icon.red { background: rgba(255,80,80,.12); }
    .info-meta strong { display: block; font-family: 'Syne', sans-serif; font-weight: 700; font-size: .95rem; color: var(--heading); margin-bottom: .2rem; }
    .info-meta span { font-size: .77rem; color: var(--muted); }

    /* WHAT I DO */
    #what-i-do { background: var(--surface); }
    .roles-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem; margin-top: 3rem;
    }
    .role-card {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.75rem;
      transition: border-color .3s, transform .3s;
      position: relative; overflow: hidden;
    }
    .role-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      opacity: 0; transition: opacity .3s;
    }
    .role-card:hover { border-color: rgba(110,231,183,.3); transform: translateY(-5px); }
    .role-card:hover::after { opacity: 1; }
    .role-icon { font-size: 1.9rem; margin-bottom: 1.1rem; display: block; }
    .role-card h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.05rem; color: var(--heading); margin-bottom: .65rem; }
    .role-card p { font-size: .81rem; color: var(--muted); line-height: 1.85; }

    /* COMMUNITY */
    #community { }
    .community-inner {
      display: grid; grid-template-columns: 1.2fr .9fr; gap: 5rem;
      align-items: start; margin-top: 2.5rem;
    }
    .community-text h3 {
      font-family: 'Instrument Serif', serif; font-size: 1.75rem;
      color: var(--heading); margin-bottom: 1rem; font-style: italic;
    }
    .community-text p { font-size: .87rem; color: var(--muted); line-height: 1.9; margin-bottom: .9rem; }
    .feature-list { list-style: none; margin: 1.5rem 0; }
    .feature-list li {
      display: flex; align-items: flex-start; gap: .75rem;
      font-size: .83rem; color: var(--muted); margin-bottom: .85rem; line-height: 1.65;
    }
    .feature-list li::before { content: '→'; color: var(--accent); flex-shrink: 0; }

    .community-cards { display: flex; flex-direction: column; gap: 1rem; }
    .comm-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.4rem 1.6rem;
      display: flex; align-items: center; gap: 1.1rem;
      text-decoration: none; transition: all .3s;
    }
    .comm-card:hover { border-color: var(--accent); transform: translateX(4px); }
    .comm-card-icon { width: 42px; height: 42px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .comm-card-icon.disc { background: rgba(88,101,242,.18); }
    .comm-card-icon.yt { background: rgba(255,48,48,.14); }
    .comm-card-icon.web { background: rgba(110,231,183,.12); }
    .comm-card-meta strong { display: block; font-family: 'Syne', sans-serif; font-size: .9rem; color: var(--heading); font-weight: 700; margin-bottom: .18rem; }
    .comm-card-meta span { font-size: .74rem; color: var(--muted); }
    .comm-card-arrow { margin-left: auto; color: var(--muted); font-size: .9rem; transition: color .3s, transform .3s; }
    .comm-card:hover .comm-card-arrow { color: var(--accent); transform: translateX(3px); }

    /* MENTORSHIP */
    #mentorship { background: var(--surface); }
    .mentorship-inner {
      display: grid; grid-template-columns: 1fr 1.1fr; gap: 4rem;
      align-items: start; margin-top: 2.5rem;
    }
    .badges { display: flex; flex-wrap: wrap; gap: .75rem; margin: 1.5rem 0; }
    .badge {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 6px; padding: .5rem 1rem;
      font-size: .78rem; color: var(--text);
    }
    .badge .dot { width: 8px; height: 8px; border-radius: 50%; }
    .badge .dot.gold { background: #fbbf24; }
    .badge .dot.purple { background: #a78bfa; }
    .badge .dot.green { background: var(--accent); }

    .sessions-stat {
      display: inline-flex; align-items: baseline; gap: .5rem;
      margin: 1rem 0;
    }
    .sessions-stat .big {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 4rem;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1;
    }
    .sessions-stat .label { font-size: .82rem; color: var(--muted); }

    .rating-row { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
    .stars { color: #fbbf24; font-size: 1.1rem; letter-spacing: .1em; }
    .rating-row span { font-size: .82rem; color: var(--muted); }

    .testimonials { display: flex; flex-direction: column; gap: 1.1rem; }
    .testimonial {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.5rem;
      transition: border-color .3s;
    }
    .testimonial:hover { border-color: rgba(110,231,183,.3); }
    .testimonial-quote { font-size: .82rem; color: var(--muted); line-height: 1.85; margin-bottom: 1rem; font-style: italic; }
    .testimonial-quote::before { content: '"'; color: var(--accent); font-size: 1.1rem; }
    .testimonial-quote::after { content: '"'; color: var(--accent); font-size: 1.1rem; }
    .testimonial-author { display: flex; align-items: center; justify-content: space-between; }
    .testimonial-author strong { font-size: .8rem; color: var(--text); font-weight: 500; }
    .testimonial-author .date { font-size: .72rem; color: var(--muted); }

    /* SKILLS */
    #skills { }
    .skills-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.25rem; margin-top: 3rem;
    }
    .skill-group {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 1.6rem;
    }
    .skill-group-title {
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: .8rem;
      letter-spacing: .12em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.1rem;
    }
    .skill-tags { display: flex; flex-wrap: wrap; gap: .45rem; }
    .skill-tag {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 4px; padding: .3rem .7rem;
      font-size: .73rem; color: var(--muted); transition: all .2s;
    }
    .skill-tag:hover { border-color: var(--accent2); color: var(--accent2); }

    /* CONTACT */
    #contact { background: var(--surface); text-align: center; }
    #contact h2 { margin-bottom: .75rem; }
    #contact > p { color: var(--muted); font-size: .88rem; margin-bottom: 3rem; }
    .contact-grid {
      display: flex; justify-content: center; flex-wrap: wrap; gap: .9rem;
    }
    .contact-pill {
      display: inline-flex; align-items: center; gap: .6rem;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 100px; padding: .75rem 1.5rem;
      text-decoration: none; color: var(--muted);
      font-size: .8rem; transition: all .25s;
    }
    .contact-pill:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-3px); box-shadow: 0 8px 25px rgba(110,231,183,.1); }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem 3rem;
      display: flex; justify-content: space-between; align-items: center;
      font-size: .73rem; color: var(--muted);
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--accent); }

    /* ANIMATIONS */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .fu { animation: fadeUp .7s ease both; }
    .d1 { animation-delay: .1s; } .d2 { animation-delay: .22s; } .d3 { animation-delay: .36s; } .d4 { animation-delay: .5s; } .d5 { animation-delay: .64s; }

    /* RESPONSIVE */
    @media (max-width: 960px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      section { padding: 4rem 1.5rem; }
      #hero { padding: 7rem 1.5rem 4rem; }
      #about, .community-inner, .mentorship-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .roles-grid { grid-template-columns: 1fr 1fr; }
      footer { flex-direction: column; gap: .5rem; text-align: center; }
    }
    @media (max-width: 600px) {
      .roles-grid { grid-template-columns: 1fr; }
      h1 { font-size: 3rem; }
    }
  </style>
</head>
